# TradersMind — environment config. Copy to .env and fill in. Never commit .env.

# --- Trading mode (CLAUDE.md §5) ---
# Exactly two values: demo | live. There is no "paper" value and no
# paper-simulation code path — every trade is a real order.
TRADING_MODE=demo
# Requires the §10 demo-trade gate (100 completed demo trades) before this
# may safely be true. main.py enforces the gate at boot for TRADING_MODE=live;
# it does not gate AUTO_EXECUTE itself, so keep this false until you trust the tap flow.
AUTO_EXECUTE=false

# --- Webhook (TradingView -> TradersMind) ---
# Long random string. Must match the ?key= param on the TradingView webhook URL.
WEBHOOK_SECRET=change-me
ALLOWED_PAIRS=R_10,R_25,R_50,R_75,R_100,1HZ10V,1HZ25V,1HZ50V,1HZ75V,1HZ100V
ALLOWED_TFS=1,5,15,60,240

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Deriv ---
# Deriv retired the legacy WebSocket API for migrated accounts — TradersMind
# buys through the Bulk Purchase REST endpoint (see bridge/deriv_client.py).
# Register your own app id at https://api.deriv.com/.
DERIV_APP_ID=1089
DERIV_API_TOKEN=
# Bulk Purchase requires an account id alongside the token (format "DOT...",
# visible in the API Playground's account switcher). CLAUDE.md §5 doesn't
# list this var — it's an addition the real endpoint requires; see the
# jarvis/ pivot documented in SYSTEM_DIAGNOSTIC.md §4/§6.
DERIV_ACCOUNT_ID=

# --- Risk Governor (§10) ---
MIN_STAKE=0.35
MAX_DYNAMIC_STAKE=1.00
MAX_STAKE_PER_TRADE=5.0
DAILY_LOSS_LIMIT=50.0
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_MINUTES_AFTER_LOSS=5
HEAT_THRESHOLD_PERCENT=20.0

WEBHOOK_PORT=8080
