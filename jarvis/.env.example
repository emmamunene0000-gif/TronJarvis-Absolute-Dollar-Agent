# JARVIS — environment config. Copy to .env and fill in. Never commit .env.

# --- Webhook (TradingView -> Jarvis) ---
# Long random string. Must match the ?key= param on the TradingView webhook URL.
WEBHOOK_SECRET=change-me

# --- Telegram ---
# Create a bot via @BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=
# Run Jarvis, send /start to your bot, it replies with your id — paste it here.
# Only this id may tap trade buttons.
TELEGRAM_OPERATOR_ID=0
# Optional: @channelname or numeric id for the Beta Operators broadcast copy. Blank = off.
TELEGRAM_BROADCAST_ID=

# --- Deriv ---
# Register your own app id at https://api.deriv.com (also where affiliate/IB markup attaches).
DERIV_APP_ID=1089
# API tokens: Deriv -> Settings -> API Token. Create one per account with `trade` + `read` scopes.
DERIV_TOKEN_DEMO=
DERIV_TOKEN_REAL=
# Hard switch: "demo" or "real". Keep on demo until the ledger proves the pipeline clean.
DERIV_ENV=demo

# --- Risk Governor ---
STAKE_DEFAULT=1.0
STAKE_MAX=10.0
DAILY_LOSS_CAP=20.0
MAX_CONCURRENT=3
MULTIPLIER_DEFAULT=100

# --- Auto-trader (leave off until the demo auto ledger earns it) ---
AUTO_TRADE=false
AUTO_MIN_CONFIDENCE=80

# --- Database ---
DB_PATH=jarvis.db
